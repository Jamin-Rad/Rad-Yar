# Vorlage für .env.local – diese Beispiel-Datei darf ins Git-Repo,
# die echte .env.local mit den tatsächlichen Schlüsseln NIEMALS!
#
# Werte findest du in deinem Supabase-Projekt unter:
# Project Settings → API Keys

NEXT_PUBLIC_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# Google Cloud Text-to-Speech für die Hörübungen
GOOGLE_TTS_API_KEY=
GOOGLE_TTS_VOICE=de-DE-Wavenet-C
GOOGLE_TTS_RATE=0.92

# Öffentliche Basis-URL für Linkvorschauen, z. B. https://radyar.de
NEXT_PUBLIC_SITE_URL=

# Kontaktformular (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
CONTACT_FROM_EMAIL=RadYar <kontakt@deine-verifizierte-domain.de>
CONTACT_TO_EMAIL=dr.benjamin.zia@gmail.com
